PORT=5000

# MongoDB
MONGO_URI=mongodb://localhost:27017/gstrisk

# Neo4j (use bolt:// for single-instance; neo4j:// causes "No routing servers" error)
# Set NEO4J_ENABLED=false to run without Neo4j (graph features disabled)
NEO4J_ENABLED=true
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here

# ML model API
ML_API_URL=http://localhost:6001
